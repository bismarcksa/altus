    private void enviarFoto(String novoNome, MultipartFile arquivo) throws IOException {

        PutObjectRequest request = PutObjectRequest.builder()
                .bucket(BUCKET)
                .key(novoNome)
                .contentType(arquivo.getContentType())
                .acl(ObjectCannedACL.PUBLIC_READ)
                .build();

        		s3config.s3Client().putObject(request, RequestBody.fromBytes(arquivo.getBytes())
        );
    }

