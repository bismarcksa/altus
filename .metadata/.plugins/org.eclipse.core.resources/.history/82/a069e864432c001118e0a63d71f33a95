package com.altus.model.validation;

import java.util.ArrayList;
import java.util.List;

import org.hibernate.validator.spi.group.DefaultGroupSequenceProvider;
import com.altus.model.Funcionario;

public class FuncionarioGroupSequenceProvider implements DefaultGroupSequenceProvider<Funcionario>{

	@Override
	public List<Class<?>> getValidationGroups(Funcionario Funcionario) {
		List<Class<?>> grupos = new ArrayList<>();
		grupos.add(Funcionario.class);
		
		if (isPessoaSelecionada(Funcionario)) {
			grupos.add(Funcionario.getTipoPessoa().getGrupo());          
	    }
		
		return grupos;
	}
	
	public boolean isPessoaSelecionada(Funcionario Funcionario) {
		return Funcionario != null && Funcionario.getTipoPessoa() != null;
	}
	
}
