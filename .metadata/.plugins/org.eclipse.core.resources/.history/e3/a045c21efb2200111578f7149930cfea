	private byte[] conteudo; // Armazena os bytes reais da foto
    private String nomeOriginal;
    private String contentType;
    private DeferredResult<FotoDTO> resultado;
    private FotoStorage fotoStorage;

    public FotoStorageRunnable(MultipartFile[] files, DeferredResult<FotoDTO> resultado, FotoStorage fotoStorage) {
        try {
            // Lemos os bytes AQUI, na Thread principal, onde o arquivo ainda existe
            this.conteudo = files[0].getBytes();
            this.nomeOriginal = files[0].getOriginalFilename();
            this.contentType = files[0].getContentType();
        } catch (IOException e) {
            throw new RuntimeException("Erro ao ler bytes do arquivo", e);
        }
        this.resultado = resultado;
        this.fotoStorage = fotoStorage;
    }

    @Override
    public void run() {
        // Agora você precisa de um método no FotoStorage que aceite byte[]
        // Ou adaptar o salvar para lidar com isso
        String nomeFoto = this.fotoStorage.salvar(conteudo, nomeOriginal, contentType);
        
        resultado.setResult(new FotoDTO(nomeFoto, contentType, fotoStorage.getUrl(nomeFoto)));
    }
	
}
